# rename this file to .env and adapt it to your needs
# do not put this file in your git, it will expose your passwords!
# in github use github secrets: https://docs.github.com/en/actions/security-guides/encrypted-secrets

######### SERVER CONFIGURATION #########
PORT=8080
NOTES_LISTEN_ADDRESS=127.0.0.1:8080
NOTES_SHUTDOWN_TIMEOUT_SECONDS=10

######### DATABASE CONFIGURATION #########
DB_DRIVER=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=go_mcp_notes_db_schema
DB_USER=go_mcp_notes_db_schema
DB_PASSWORD=Choose_your_own_password_here
DB_SSL_MODE=prefer
DATABASE_URL=postgres://go_mcp_notes_db_schema:Choose_your_own_password_here@127.0.0.1:5432/go_mcp_notes_db_schema?sslmode=prefer
NOTES_DB_MAX_CONNECTIONS=10

######### NOTES AUTHENTICATION #########
# jwt: verify tokens issued by go-cloud-k8s-auth using the JWT settings below.
# dev: accept NOTES_DEV_TOKEN for one explicit local development user.
NOTES_AUTH_MODE=jwt
# Base URL of the go-cloud-k8s-auth service. Used by the frontend for SSO
# (sign-in redirect + silent token mint) and by the server to introspect
# personal access tokens (pat_...).
AUTH_SERVER_URL=http://localhost:9090
NOTES_DEV_TOKEN=dev-local-token
NOTES_DEV_USER_ID=1
NOTES_DEV_USER_EMAIL=dev@localhost
NOTES_DEV_USER_NAME=Local Notes User

######### JSON WEB TOKEN CONFIGURATION #########
JWT_SECRET="Use your nice and complicated token here"
JWT_ISSUER_ID=2490AD68-3AA9-4C17-BB49-33C2F202B754
JWT_CONTEXT_KEY=yourContextKey
JWT_DURATION_MINUTES=15
JWT_AUTH_URL=/login
JWT_STATUS_URL=/status

######### ADMIN USER #########
ADMIN_USER=goadmin
ADMIN_EMAIL=goadmin@yourdomain.org
ADMIN_ID=960901
ADMIN_PASSWORD=Choose_your_own_admin_password_here

######### LOG CONFIGURATION #########
# LOG_FILE: string containing the filename, OR stdout, stderr, DISCARD. default: stderr
LOG_FILE=stderr
# LOG_LEVEL: debug, info, warn, error, fatal (or 0-4)
LOG_LEVEL=info
